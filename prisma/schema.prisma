generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  active
  archived
}

enum SourceType {
  note
  voice
  text
  link
  manual
}

enum ItemType {
  feature
  bug
  regression
  decision
  question
  chore
  opportunity
}

enum DevItemStatus {
  captured
  triaged
  approved
  in_build
  shipped
  duplicate
  rejected
  archived
}

enum Priority {
  unset
  low
  medium
  high
  urgent
}

enum ArtifactType {
  transcript
  attachment
  note
  link
}

enum BuildStatus {
  active
  merged
  abandoned
}

enum CurationState {
  unreviewed
  keep
  archive_junk
  duplicate
  merge_candidate
  canonical
}

enum InitiativeStatus {
  proposed
  active
  next
  paused
  completed
  archived
}

enum InitiativePriority {
  low
  medium
  high
  critical
}

enum StrategicValue {
  beta_critical
  launch_critical
  growth
  delight
  infrastructure
  research
  future_vision
}

enum WorkflowCommand {
  capture
  architectural_intake
  change_classify
  investigate
  ship
  investment
}

enum IntakeStatus {
  processing
  complete
  accepted
  rejected
}

enum InvestmentCategory {
  learning
  experimentation
  environment
  infrastructure
  relationships
  business
  health
}

enum InvestmentStatus {
  captured
  scheduled
  in_progress
  completed
  archived
}

enum InvestmentLeverage {
  low
  medium
  high
  compound
}

enum CapturePromotion {
  architect
  bug
  audit
  research
}

enum ArchitectSessionStatus {
  active
  initiative_created
  discarded
  archived
}

enum AuditSessionStatus {
  active
  polish_initiative_created
  discarded
  archived
}

enum ResearchQuestionStatus {
  open
  converging
  answered
  archived
}

enum ThesisStatus {
  competing
  leading
  weakened
  disproven
  archived
}

enum EvidenceSource {
  product_analytics
  user_interview
  artist_feedback
  founder_observation
  conference_notes
  customer_conversation
  research
  experiment
}

enum EvidenceEffect {
  supports
  weakens
  neutral
}

enum ResearchNoteKind {
  article
  book
  paper
  podcast
  conference
  interview
  competitor
  founder_observation
  other
}

model Project {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  status      ProjectStatus @default(active)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  devItems              DevItem[]
  initiatives           Initiative[]
  protectedDomains      ProtectedDomain[]
  architecturalIntakes  ArchitecturalIntake[]
  investments           Investment[]
  architectSessions     ArchitectSession[]
  auditSessions         AuditSession[]
  principleLinks        ProjectPrinciple[]
  thesisLinks           ProjectThesis[]
  executiveReviews      ExecutiveReview[]

  @@map("projects")
}

model ArchitectSession {
  id            String                 @id @default(cuid())
  projectId     String                 @map("project_id")
  captureId     String?                @map("capture_id")
  status        ArchitectSessionStatus @default(active)
  originalInput String                 @map("original_input")
  analysisJson  Json?                  @map("analysis_json")
  messagesJson  Json                   @default("[]") @map("messages_json")
  initiativeId  String?                @unique @map("initiative_id")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  project    Project     @relation(fields: [projectId], references: [id])
  capture    DevItem?    @relation(fields: [captureId], references: [id], onDelete: SetNull)
  initiative Initiative? @relation(fields: [initiativeId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([captureId])
  @@index([status])
  @@index([createdAt])
  @@map("architect_sessions")
}

model AuditSession {
  id            String             @id @default(cuid())
  projectId     String             @map("project_id")
  captureId     String             @map("capture_id")
  status        AuditSessionStatus @default(active)
  originalInput String             @map("original_input")
  scopeJson     Json?              @map("scope_json")
  initiativeId  String?            @unique @map("initiative_id")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  project    Project     @relation(fields: [projectId], references: [id])
  capture    DevItem     @relation(fields: [captureId], references: [id], onDelete: Cascade)
  initiative Initiative? @relation(fields: [initiativeId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([captureId])
  @@index([status])
  @@index([createdAt])
  @@map("audit_sessions")
}

model ArchitecturalIntake {
  id              String          @id @default(cuid())
  projectId       String          @map("project_id")
  command         WorkflowCommand
  rawInput        String          @map("raw_input")
  intent          String?
  briefMarkdown   String?         @map("brief_markdown")
  resultJson      Json?           @map("result_json")
  status          IntakeStatus    @default(complete)
  acceptedItemIds Json?           @map("accepted_item_ids")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([command])
  @@index([status])
  @@index([createdAt])
  @@map("architectural_intakes")
}

model Investment {
  id               String             @id @default(cuid())
  projectId        String             @map("project_id")
  title            String
  description      String?
  rawInput         String?            @map("raw_input")
  category         InvestmentCategory
  status           InvestmentStatus   @default(captured)
  capabilityTarget String?            @map("capability_target")
  intentConnection String?            @map("intent_connection")
  leverage         InvestmentLeverage @default(medium)
  estimatedHours   Float?             @map("estimated_hours")
  compoundingValue String?            @map("compounding_value")
  reflection       String?
  capabilityAdded  String?            @map("capability_added")
  scheduledFor     DateTime?          @map("scheduled_for")
  completedAt      DateTime?          @map("completed_at")
  intakeId         String?            @map("intake_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  project         Project                @relation(fields: [projectId], references: [id])
  initiativeLinks InitiativeInvestment[]
  workItemLinks   InvestmentWorkItem[]

  @@index([projectId])
  @@index([category])
  @@index([status])
  @@index([createdAt])
  @@map("investments")
}

model InitiativeInvestment {
  id           String   @id @default(cuid())
  initiativeId String   @map("initiative_id")
  investmentId String   @map("investment_id")
  recommended  Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  initiative Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  investment Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@unique([initiativeId, investmentId])
  @@index([initiativeId])
  @@index([investmentId])
  @@map("initiative_investments")
}

model InvestmentWorkItem {
  id           String   @id @default(cuid())
  investmentId String   @map("investment_id")
  devItemId    String   @map("dev_item_id")
  relationship String   @default("enables")
  createdAt    DateTime @default(now()) @map("created_at")

  investment Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  devItem    DevItem    @relation(fields: [devItemId], references: [id], onDelete: Cascade)

  @@unique([investmentId, devItemId])
  @@index([investmentId])
  @@index([devItemId])
  @@map("investment_work_items")
}

model DevItem {
  id                  String        @id @default(cuid())
  projectId           String        @map("project_id")
  title               String
  rawText             String        @map("raw_text")
  normalizedSummary   String        @map("normalized_summary")
  sourceType          SourceType    @map("source_type")
  itemType            ItemType      @map("item_type")
  status              DevItemStatus @default(captured)
  priority            Priority      @default(unset)
  duplicateOfId       String?       @map("duplicate_of_id")
  confidenceScore     Float?        @map("confidence_score")
  suggestedBranchName String?       @map("suggested_branch_name")
  suggestedCommand    String?       @map("suggested_command")
  externalKey         String?       @unique @map("external_key")
  curationState       CurationState @default(unreviewed) @map("curation_state")
  canonicalItemId     String?       @map("canonical_item_id")
  curationReason      String?           @map("curation_reason")
  qualityScore        Float?            @map("quality_score")
  isCapture           Boolean           @default(false) @map("is_capture")
  promotedTo          CapturePromotion? @map("promoted_to")
  sourceCaptureId     String?           @map("source_capture_id")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  project         Project         @relation(fields: [projectId], references: [id])
  duplicateOf     DevItem?        @relation("DuplicateRelation", fields: [duplicateOfId], references: [id])
  duplicates      DevItem[]       @relation("DuplicateRelation")
  canonicalItem   DevItem?        @relation("CanonicalRelation", fields: [canonicalItemId], references: [id])
  canonicalFor    DevItem[]       @relation("CanonicalRelation")
  matches       DevItemMatch[]  @relation("SourceItem")
  matchedBy     DevItemMatch[]  @relation("MatchedItem")
  artifacts       DevArtifact[]
  activity        DevActivity[]
  builds          DevBuild[]
  initiativeItems       InitiativeItem[]
  protectedDomainChanges ProtectedDomainChange[]
  investmentLinks       InvestmentWorkItem[]
  architectSessions     ArchitectSession[]
  auditSessions         AuditSession[]
  sourceCapture         DevItem?           @relation("CaptureProvenance", fields: [sourceCaptureId], references: [id], onDelete: SetNull)
  derivedFromCapture    DevItem[]          @relation("CaptureProvenance")

  @@index([projectId])
  @@index([status])
  @@index([itemType])
  @@index([priority])
  @@index([createdAt])
  @@index([curationState])
  @@index([isCapture])
  @@index([sourceCaptureId])
  @@map("dev_items")
}

model DevItemMatch {
  id              String   @id @default(cuid())
  devItemId       String   @map("dev_item_id")
  matchedItemId   String   @map("matched_item_id")
  similarityScore Float    @map("similarity_score")
  matchReason     String   @map("match_reason")
  createdAt       DateTime @default(now()) @map("created_at")

  devItem     DevItem @relation("SourceItem", fields: [devItemId], references: [id], onDelete: Cascade)
  matchedItem DevItem @relation("MatchedItem", fields: [matchedItemId], references: [id], onDelete: Cascade)

  @@index([devItemId])
  @@index([matchedItemId])
  @@map("dev_item_matches")
}

model DevArtifact {
  id           String       @id @default(cuid())
  devItemId    String       @map("dev_item_id")
  artifactType ArtifactType @map("artifact_type")
  content      String?
  url          String?
  metadataJson Json?        @map("metadata_json")
  createdAt    DateTime     @default(now()) @map("created_at")

  devItem DevItem @relation(fields: [devItemId], references: [id], onDelete: Cascade)

  @@index([devItemId])
  @@map("dev_artifacts")
}

model DevActivity {
  id        String   @id @default(cuid())
  devItemId String   @map("dev_item_id")
  action    String
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  devItem DevItem @relation(fields: [devItemId], references: [id], onDelete: Cascade)

  @@index([devItemId])
  @@map("dev_activity")
}

model DevBuild {
  id                 String      @id @default(cuid())
  devItemId          String      @map("dev_item_id")
  repo               String
  branchName         String      @map("branch_name")
  commandUsed        String?     @map("command_used")
  planDocPath        String?     @map("plan_doc_path")
  contractReportPath String?     @map("contract_report_path")
  status             BuildStatus @default(active)
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  devItem DevItem @relation(fields: [devItemId], references: [id], onDelete: Cascade)

  @@index([devItemId])
  @@map("dev_builds")
}

model Initiative {
  id             String             @id @default(cuid())
  projectId      String             @map("project_id")
  title          String
  description    String?
  status         InitiativeStatus   @default(proposed)
  priority       InitiativePriority @default(medium)
  strategicValue StrategicValue     @default(infrastructure) @map("strategic_value")
  targetRelease  String?            @map("target_release")
  scoreOverride  Int?               @map("score_override")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  project Project          @relation(fields: [projectId], references: [id])
  items   InitiativeItem[]
  investmentLinks InitiativeInvestment[]
  thesisId         String?          @map("thesis_id")
  architectSession ArchitectSession?
  auditSession     AuditSession?
  thesis           Thesis?          @relation(fields: [thesisId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@index([strategicValue])
  @@index([thesisId])
  @@map("initiatives")
}

model Principle {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  originStory String?  @map("origin_story")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  researchQuestions ResearchQuestion[]
  thesisLinks       ThesisPrinciple[]
  projectLinks      ProjectPrinciple[]

  @@map("principles")
}

model ResearchQuestion {
  id                   String                 @id @default(cuid())
  principleId          String?                @map("principle_id")
  question             String
  whyItMatters         String?                @map("why_it_matters")
  currentUnderstanding String?                @map("current_understanding")
  unknowns             Json                   @default("[]")
  status               ResearchQuestionStatus @default(open)
  nextExperiment       String?                @map("next_experiment")
  brainstormJson       Json?                  @map("brainstorm_json")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")

  principle     Principle?     @relation(fields: [principleId], references: [id], onDelete: SetNull)
  theses        Thesis[]
  researchNotes ResearchNote[]

  @@index([principleId])
  @@index([status])
  @@map("research_questions")
}

model Thesis {
  id                 String       @id @default(cuid())
  researchQuestionId String       @map("research_question_id")
  statement          String
  confidence         Int          @default(50)
  status             ThesisStatus @default(competing)
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  researchQuestion    ResearchQuestion      @relation(fields: [researchQuestionId], references: [id], onDelete: Cascade)
  principleLinks      ThesisPrinciple[]
  projectLinks        ProjectThesis[]
  initiatives         Initiative[]
  evidenceItems       Evidence[]
  confidenceSnapshots ConfidenceSnapshot[]

  @@index([researchQuestionId])
  @@index([status])
  @@map("theses")
}

model Evidence {
  id          String         @id @default(cuid())
  thesisId    String         @map("thesis_id")
  title       String
  description String?
  source      EvidenceSource
  effect      EvidenceEffect @default(supports)
  strength    Int            @default(50)
  createdAt   DateTime       @default(now()) @map("created_at")

  thesis Thesis @relation(fields: [thesisId], references: [id], onDelete: Cascade)

  @@index([thesisId])
  @@map("evidence")
}

model ResearchNote {
  id                 String           @id @default(cuid())
  researchQuestionId String           @map("research_question_id")
  kind               ResearchNoteKind
  title              String
  url                String?
  excerpt            String?
  createdAt          DateTime         @default(now()) @map("created_at")

  researchQuestion ResearchQuestion @relation(fields: [researchQuestionId], references: [id], onDelete: Cascade)

  @@index([researchQuestionId])
  @@map("research_notes")
}

model ConfidenceSnapshot {
  id         String   @id @default(cuid())
  thesisId   String   @map("thesis_id")
  confidence Int
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")

  thesis Thesis @relation(fields: [thesisId], references: [id], onDelete: Cascade)

  @@index([thesisId])
  @@map("confidence_snapshots")
}

model ExecutiveReview {
  id          String   @id @default(cuid())
  projectId   String?  @map("project_id")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  summaryJson Json     @map("summary_json")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([periodEnd])
  @@map("executive_reviews")
}

model ThesisPrinciple {
  id          String @id @default(cuid())
  thesisId    String @map("thesis_id")
  principleId String @map("principle_id")

  thesis    Thesis    @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  principle Principle @relation(fields: [principleId], references: [id], onDelete: Cascade)

  @@unique([thesisId, principleId])
  @@map("thesis_principles")
}

model ProjectPrinciple {
  id          String @id @default(cuid())
  projectId   String @map("project_id")
  principleId String @map("principle_id")

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  principle Principle @relation(fields: [principleId], references: [id], onDelete: Cascade)

  @@unique([projectId, principleId])
  @@map("project_principles")
}

model ProjectThesis {
  id        String @id @default(cuid())
  projectId String @map("project_id")
  thesisId  String @map("thesis_id")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  thesis  Thesis  @relation(fields: [thesisId], references: [id], onDelete: Cascade)

  @@unique([projectId, thesisId])
  @@map("project_theses")
}

model InitiativeItem {
  id           String   @id @default(cuid())
  initiativeId String   @map("initiative_id")
  devItemId    String   @map("dev_item_id")
  createdAt    DateTime @default(now()) @map("created_at")

  initiative Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  devItem    DevItem    @relation(fields: [devItemId], references: [id], onDelete: Cascade)

  @@unique([initiativeId, devItemId])
  @@index([initiativeId])
  @@index([devItemId])
  @@map("initiative_items")
}

model IngestKey {
  id         String    @id @default(cuid())
  label      String    @default("DevAnvil Ingest Key")
  keyPrefix  String    @map("key_prefix")
  keyHash    String    @unique @map("key_hash")
  createdAt  DateTime  @default(now()) @map("created_at")
  revokedAt  DateTime? @map("revoked_at")
  lastUsedAt DateTime? @map("last_used_at")

  @@index([keyPrefix])
  @@map("ingest_keys")
}

enum ProtectionLevel {
  advisory
  guarded
  protected
  locked
}

enum ProtectedDomainStatus {
  active
  archived
}

enum DomainArtifactKind {
  adr
  runtime_contract
  visual_contract
  catalog
  golden_master
  runtime_inventory
  test_suite
  regression_log
  decision_record
}

enum ExtensionPointCategory {
  allowed
  requires_adr
}

enum DomainChangeStatus {
  open
  in_review
  merged
  blocked
}

enum DomainViolationSeverity {
  low
  medium
  high
  critical
}

enum RegressionStatus {
  passing
  failing
  unknown
  not_run
}

model ProtectedDomain {
  id                  String                @id @default(cuid())
  slug                String                @unique
  name                String
  description         String?
  owner               String
  status              ProtectedDomainStatus @default(active)
  protectionLevel     ProtectionLevel       @default(advisory) @map("protection_level")
  projectId           String?               @map("project_id")
  keywords            Json                  @default("[]")
  pathPatterns        Json                  @default("[]") @map("path_patterns")
  lastAuditAt         DateTime?             @map("last_audit_at")
  lastGoldenMasterAt  DateTime?             @map("last_golden_master_at")
  contractVersion     String?               @map("contract_version")
  inventoryVersion    String?               @map("inventory_version")
  regressionStatus    RegressionStatus      @default(unknown) @map("regression_status")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  project        Project?                     @relation(fields: [projectId], references: [id])
  artifacts      ProtectedDomainArtifact[]
  changeGates    ProtectedDomainChangeGate[]
  extensionPoints ProtectedDomainExtensionPoint[]
  changes        ProtectedDomainChange[]
  violations     ProtectedDomainViolation[]
  audits         ProtectedDomainAudit[]

  @@index([projectId])
  @@index([protectionLevel])
  @@index([status])
  @@map("protected_domains")
}

model ProtectedDomainArtifact {
  id           String             @id @default(cuid())
  domainId     String             @map("domain_id")
  kind         DomainArtifactKind
  title        String
  path         String?
  version      String?
  metadataJson Json?              @map("metadata_json")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  domain ProtectedDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([domainId])
  @@index([kind])
  @@map("protected_domain_artifacts")
}

model ProtectedDomainChangeGate {
  id          String  @id @default(cuid())
  domainId    String  @map("domain_id")
  name        String
  description String?
  required    Boolean @default(true)
  sortOrder   Int     @default(0) @map("sort_order")

  domain ProtectedDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([domainId])
  @@map("protected_domain_change_gates")
}

model ProtectedDomainExtensionPoint {
  id          String                 @id @default(cuid())
  domainId    String                 @map("domain_id")
  name        String
  description String?
  category    ExtensionPointCategory

  domain ProtectedDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([domainId])
  @@map("protected_domain_extension_points")
}

model ProtectedDomainChange {
  id          String             @id @default(cuid())
  domainId    String             @map("domain_id")
  devItemId   String?            @map("dev_item_id")
  title       String
  description String?
  risk        String?
  status      DomainChangeStatus @default(open)
  gatesJson   Json?              @map("gates_json")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  domain  ProtectedDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  devItem DevItem?        @relation(fields: [devItemId], references: [id], onDelete: SetNull)

  @@index([domainId])
  @@index([devItemId])
  @@index([status])
  @@map("protected_domain_changes")
}

model ProtectedDomainViolation {
  id          String                  @id @default(cuid())
  domainId    String                  @map("domain_id")
  description String
  severity    DomainViolationSeverity @default(medium)
  resolvedAt  DateTime?               @map("resolved_at")
  createdAt   DateTime                @default(now()) @map("created_at")

  domain ProtectedDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([domainId])
  @@map("protected_domain_violations")
}

model ProtectedDomainAudit {
  id        String   @id @default(cuid())
  domainId  String   @map("domain_id")
  note      String
  auditor   String?
  passed    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  domain ProtectedDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([domainId])
  @@map("protected_domain_audits")
}
